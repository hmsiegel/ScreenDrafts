meta {
  name: Access Token
  type: http
  seq: 1
}

post {
  url: http://localhost:18080/realms/screendrafts/protocol/openid-connect/token
  body: formUrlEncoded
  auth: bearer
}

auth:none

body:form-urlencoded {
  grant_type: password
  client_id: screendrafts-public-client
  scope: email openid
  username: "{{username}}"
  password: "{{password}}"
}

tests {
  var jsonData = res.getBody();
  bru.setVar("token", jsonData.access_token);
}
